# Supabase public env values
# Local development icin bu dosyayi .env.local olarak kopyalayip gercek degerleri girin.
# Production degerleri Vercel > Project Settings > Environment Variables icinde tanimli olmalidir.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
